{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "dangerouslyDisablePackageManagerCheck": true,
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },
    "typecheck": {},
    "test": {},
    "test:once": {},
    "test:e2e": { "env": ["OFFLINE"] },
    "test:cts": {},
    "test:vscode": { "dependsOn": ["^build"] },
    "test:built:fast": { "dependsOn": ["^build"] },
    "bench": {},
    "bench:validate": {},

    "wesl-rand#build": { "dependsOn": ["random_wgsl#build"] },
    "wesl-vite#build": { "dependsOn": ["random_wgsl#build"] },
    "wesl-vite-minimal#build": { "dependsOn": ["random_wgsl#build"] },
    "wesl-plugin#test": { "dependsOn": ["random_wgsl#build"] },

    "//#fix:biome": {},
    "//#fix:pkgJsonFormat": {},
    "//#fix:syncpack": {},
    "//#lint:biome": {},
    "//#check:versions": {},
    "//#check:lockfile": {},
    "//#test:unit": {},
    "//#typecheck:examples": {},
    "//#typecheck:scripts": {},
    "//#test:examples": {}
  }
}
