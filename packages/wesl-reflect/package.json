{
  "name": "wesl-reflect",
  "description": "Browser-compatible reflection library for WESL/WGSL shader ASTs",
  "version": "0.0.4",
  "type": "module",
  "files": [
    "dist",
    "src"
  ],
  "repository": "github:wgsl-tooling-wg/wesl-js",
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "run-s build",
    "test": "cross-env FORCE_COLOR=1 vitest",
    "test:once": "vitest run",
    "typecheck": "tsgo"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "main": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "wesl": "workspace:*"
  },
  "keywords": [
    "reflection",
    "shader",
    "WebGPU",
    "WESL",
    "WGSL"
  ]
}
